{
  "skill_name": "kora-openapi",
  "evals": [
    {
      "id": 1,
      "name": "java-client-basic",
      "prompt": "Create an HTTP client for the OpenAPI specification petstore.yaml. Use synchronous mode (java-client). Configure generation with clientConfigPrefix: httpClient.petApi.",
      "expected_output": "Gradle build file with the openApiGenerateHttpClient task, generated PetApi interface with synchronous methods",
      "files": ["openapi-spec.yaml.template"],
      "assertions": [
        {
          "name": "build-gradle-has-openapi-generator",
          "type": "contains",
          "target": "build.gradle",
          "content": "openApiGenerateHttpClient",
          "description": "build.gradle contains the openApiGenerateHttpClient task"
        },
        {
          "name": "config-has-client-config-prefix",
          "type": "contains",
          "target": "build.gradle",
          "content": "clientConfigPrefix",
          "description": "clientConfigPrefix configured in configOptions"
        },
        {
          "name": "mode-is-java-client",
          "type": "contains",
          "target": "build.gradle",
          "content": "java-client",
          "description": "mode set to java-client"
        },
        {
          "name": "generated-interface-has-sync-methods",
          "type": "contains",
          "target": "PetApi.java",
          "content": "Pet getPetById",
          "description": "Generated interface has synchronous methods"
        }
      ]
    },
    {
      "id": 2,
      "name": "java-server-basic",
      "prompt": "Create an HTTP server for the OpenAPI specification petstore.yaml. Use synchronous mode (java-server) with validation enabled. Configure delegateMethodBodyMode: throw-exception.",
      "expected_output": "Gradle build file with the openApiGenerateHttpServer task, generated PetApiDelegate interface with methods returning ApiResponses subclass (e.g., PetApiResponses.GetPetByIdApiResponse)",
      "files": ["openapi-spec.yaml.template"],
      "assertions": [
        {
          "name": "build-gradle-has-server-task",
          "type": "contains",
          "target": "build.gradle",
          "content": "openApiGenerateHttpServer",
          "description": "build.gradle contains the openApiGenerateHttpServer task"
        },
        {
          "name": "mode-is-java-server",
          "type": "contains",
          "target": "build.gradle",
          "content": "java-server",
          "description": "mode set to java-server"
        },
        {
          "name": "validation-enabled",
          "type": "contains",
          "target": "build.gradle",
          "content": "enableServerValidation",
          "description": "enableServerValidation: true"
        },
        {
          "name": "delegate-returns-api-responses",
          "type": "contains",
          "target": "PetApiDelegate.java",
          "content": "ApiResponses",
          "description": "Delegate methods return ApiResponses subclass"
        }
      ]
    },
    {
      "id": 3,
      "name": "kotlin-client-suspend",
      "prompt": "Create a Kotlin HTTP client for the OpenAPI specification. Use kotlin-suspend-client mode. Configure the KSP task with dependsOn from openApiGenerateHttpClient.",
      "expected_output": "build.gradle.kts with register<GenerateTask>, generated interface with suspend functions",
      "files": ["openapi-spec.yaml.template"],
      "language": "kotlin",
      "assertions": [
        {
          "name": "build-kts-has-generate-task",
          "type": "contains",
          "target": "build.gradle.kts",
          "content": "register<GenerateTask>",
          "description": "build.gradle.kts contains register<GenerateTask>"
        },
        {
          "name": "mode-is-kotlin-suspend-client",
          "type": "contains",
          "target": "build.gradle.kts",
          "content": "kotlin-suspend-client",
          "description": "mode set to kotlin-suspend-client"
        },
        {
          "name": "ksp-depends-on-generate",
          "type": "contains",
          "target": "build.gradle.kts",
          "content": "dependsOn",
          "description": "KSP task depends on openApiGenerateHttpClient"
        },
        {
          "name": "generated-interface-has-suspend",
          "type": "contains",
          "target": "PetApi.kt",
          "content": "suspend",
          "description": "Generated interface contains suspend functions"
        }
      ]
    },
    {
      "id": 4,
      "name": "client-interceptors",
      "prompt": "Configure interceptors for the HTTP client: a global logger for all operations, a metrics interceptor for tag 'pet', a tracing interceptor for tag 'shop'. Use JSON configuration in configOptions.interceptors.",
      "expected_output": "Interceptors configuration with correct type and tag for each interceptor",
      "files": [],
      "assertions": [
        {
          "name": "interceptors-config-exists",
          "type": "contains",
          "target": "build.gradle",
          "content": "interceptors",
          "description": "interceptors configuration is present"
        },
        {
          "name": "logger-interceptor-global",
          "type": "contains",
          "target": "build.gradle",
          "content": "logging",
          "description": "Logger configured for all operations"
        },
        {
          "name": "metrics-tag-pet",
          "type": "contains",
          "target": "build.gradle",
          "content": "pet",
          "description": "metrics interceptor for tag 'pet'"
        },
        {
          "name": "tracing-tag-shop",
          "type": "contains",
          "target": "build.gradle",
          "content": "shop",
          "description": "tracing interceptor for tag 'shop'"
        }
      ]
    },
    {
      "id": 5,
      "name": "client-tags",
      "prompt": "Configure tags for the HTTP client: httpClientTag and telemetryTag for operations '*' (common), 'instrument', and 'shop'.",
      "expected_output": "Tags configuration with httpClientTag and telemetryTag for each operation group",
      "files": [],
      "assertions": [
        {
          "name": "tags-config-exists",
          "type": "contains",
          "target": "build.gradle",
          "content": "tags",
          "description": "tags configuration is present"
        },
        {
          "name": "common-tag-star",
          "type": "contains",
          "target": "build.gradle",
          "content": "*",
          "description": "common tag for '*' operations"
        },
        {
          "name": "instrument-tag",
          "type": "contains",
          "target": "build.gradle",
          "content": "instrument",
          "description": "instrument tag configured"
        },
        {
          "name": "shop-tag",
          "type": "contains",
          "target": "build.gradle",
          "content": "shop",
          "description": "shop tag configured"
        }
      ]
    },
    {
      "id": 6,
      "name": "server-validation",
      "prompt": "Enable server-side validation for the OpenAPI server. What annotations will be generated for the name: string field with minLength: 1, maxLength: 100?",
      "expected_output": "enableServerValidation: true, @NotNull @Size(min=1, max=100) on the name field",
      "files": [],
      "assertions": [
        {
          "name": "validation-enabled",
          "type": "contains",
          "target": "build.gradle",
          "content": "enableServerValidation",
          "description": "enableServerValidation: true"
        },
        {
          "name": "not-null-annotation",
          "type": "contains",
          "target": "Pet.java",
          "content": "@NotNull",
          "description": "@NotNull annotation on the name field"
        },
        {
          "name": "size-annotation",
          "type": "contains",
          "target": "Pet.java",
          "content": "@Size",
          "description": "@Size(min=1, max=100) on the name field"
        }
      ]
    },
    {
      "id": 7,
      "name": "bearer-auth-extractor",
      "prompt": "Create an HttpServerPrincipalExtractor for Bearer authentication. The OpenAPI spec defines a securityScheme 'bearerAuth' with type: http, scheme: bearer.",
      "expected_output": "@Module interface with a @Tag(ApiSecurity.BearerAuth.class) method returning HttpServerPrincipalExtractor",
      "files": [],
      "assertions": [
        {
          "name": "module-annotation",
          "type": "contains",
          "target": "AuthModule.java",
          "content": "@Module",
          "description": "Class is annotated with @Module"
        },
        {
          "name": "tag-bearer-auth",
          "type": "contains",
          "target": "AuthModule.java",
          "content": "@Tag(ApiSecurity.BearerAuth.class)",
          "description": "Method has @Tag(ApiSecurity.BearerAuth.class)"
        },
        {
          "name": "returns-extractor",
          "type": "contains",
          "target": "AuthModule.java",
          "content": "HttpServerPrincipalExtractor",
          "description": "Method returns HttpServerPrincipalExtractor"
        }
      ]
    },
    {
      "id": 8,
      "name": "apikey-auth-extractor",
      "prompt": "Create an HttpServerPrincipalExtractor for API Key authentication. The OpenAPI spec defines a securityScheme 'apiKeyAuth' with type: apiKey, in: header, name: X-API-Key.",
      "expected_output": "@Module interface with a @Tag(ApiSecurity.ApiKeyAuth.class) method",
      "files": [],
      "assertions": [
        {
          "name": "module-annotation",
          "type": "contains",
          "target": "AuthModule.java",
          "content": "@Module",
          "description": "Class is annotated with @Module"
        },
        {
          "name": "tag-apikey-auth",
          "type": "contains",
          "target": "AuthModule.java",
          "content": "@Tag(ApiSecurity.ApiKeyAuth.class)",
          "description": "Method has @Tag(ApiSecurity.ApiKeyAuth.class)"
        }
      ]
    },
    {
      "id": 9,
      "name": "basic-auth-extractor",
      "prompt": "Create an HttpServerPrincipalExtractor for Basic authentication. Parse Base64-encoded credentials from the Authorization header.",
      "expected_output": "@Module interface with a @Tag(ApiSecurity.BasicAuth.class) method that parses the Basic auth header",
      "files": [],
      "assertions": [
        {
          "name": "module-annotation",
          "type": "contains",
          "target": "AuthModule.java",
          "content": "@Module",
          "description": "Class is annotated with @Module"
        },
        {
          "name": "tag-basic-auth",
          "type": "contains",
          "target": "AuthModule.java",
          "content": "@Tag(ApiSecurity.BasicAuth.class)",
          "description": "Method has @Tag(ApiSecurity.BasicAuth.class)"
        },
        {
          "name": "base64-parsing",
          "type": "contains",
          "target": "AuthModule.java",
          "content": "Base64",
          "description": "Base64 parsing is present"
        }
      ]
    },
    {
      "id": 10,
      "name": "openapi-normalizer",
      "prompt": "Configure openapiNormalizer to disable all normalizers. Which rule is enabled by default in plugin 7.0.0+ and may cause issues?",
      "expected_output": "DISABLE_ALL: true, SIMPLIFY_ONEOF_ANYOF enabled by default",
      "files": [],
      "assertions": [
        {
          "name": "disable-all-rule",
          "type": "contains",
          "target": "build.gradle",
          "content": "DISABLE_ALL",
          "description": "DISABLE_ALL: true configured"
        },
        {
          "name": "simplify-oneof-anyof",
          "type": "contains",
          "target": "build.gradle",
          "content": "SIMPLIFY_ONEOF_ANYOF",
          "description": "SIMPLIFY_ONEOF_ANYOF mentioned"
        }
      ]
    },
    {
      "id": 11,
      "name": "java-reactive-server",
      "prompt": "Create a reactive HTTP server using java-reactive-server mode. What return types will the delegate methods have?",
      "expected_output": "Mono<ApiResponses> for all delegate methods (e.g., Mono<PetApiResponses.GetPetByIdApiResponse>)",
      "files": [],

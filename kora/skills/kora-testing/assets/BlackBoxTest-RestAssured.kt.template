package ${package}

import io.restassured.RestAssured.given
import io.restassured.http.ContentType
import org.hamcrest.Matchers.*
import org.junit.jupiter.api.AfterAll
import org.junit.jupiter.api.BeforeAll
import org.junit.jupiter.api.Test

/**
 * Black-box tests with RestAssured for the HTTP API.
 *
 * Runs the application in a Docker container (AppContainer) and tests it via the HTTP API.
 * Uses RestAssured for concise BDD-style tests with JSON assertions.
 *
 * Usage options:
 * - Without a DB: remove @TestcontainersPostgreSQL and the connection field
 * - With a DB: add @TestcontainersPostgreSQL and configure the connection
 *
 * @see [RestAssured Documentation](https://rest-assured.io/)
 */
class ${className} {

    companion object {
        private val container = AppContainer.build()

        @BeforeAll
        @JvmStatic
        fun setup() {
            // For applications with a DB, uncomment:
            // container.withEnv(mapOf(
            //     "DB_URL" to "jdbc:postgresql://localhost:5432/test",
            //     "DB_USER" to "postgres",
            //     "DB_PASS" to "postgres"
            // ))
            container.start()
        }

        @AfterAll
        @JvmStatic
        fun cleanup() {
            container.stop()
        }
    }

    @Test
    fun `should get health`() {
        given()
            .baseUri(container.getURI().toString())
        .`when`()
            .get("/system/health")
        .then()
            .statusCode(200)
    }

    @Test
    fun `should create and get entity`() {
        // Arrange
        val createBody = """
            {
                "name": "test-entity",
                "description": "Test description"
            }
            """

        // Act & Assert - Create
        val entityId = given()
            .baseUri(container.getURI().toString())
            .contentType(ContentType.JSON)
            .body(createBody)
        .`when`()
            .post("/api/entities")
        .then()
            .statusCode(200)
            .body("id", notNullValue())
            .body("name", equalTo("test-entity"))
            .extract()
            .path<Int>("id")

        // Act & Assert - Get
        given()
            .baseUri(container.getURI().toString())
            .pathParam("id", entityId)
        .`when`()
            .get("/api/entities/{id}")
        .then()
            .statusCode(200)
            .body("id", equalTo(entityId))
            .body("name", equalTo("test-entity"))
    }

    @Test
    fun `should update entity`() {
        // Arrange - Create entity first
        val createBody = """
            {
                "name": "original",
                "description": "Original description"
            }
            """

        val entityId = given()
            .baseUri(container.getURI().toString())
            .contentType(ContentType.JSON)
            .body(createBody)
        .`when`()
            .post("/api/entities")
        .then()
            .statusCode(200)
            .extract().path<Int>("id")

        // Act - Update
        val updateBody = """
            {
                "name": "updated",
                "description": "Updated description"
            }
            """

        // Assert
        given()
            .baseUri(container.getURI().toString())
            .pathParam("id", entityId)
            .contentType(ContentType.JSON)
            .body(updateBody)
        .`when`()
            .put("/api/entities/{id}")
        .then()
            .statusCode(200)
            .body("id", equalTo(entityId))
            .body("name", equalTo("updated"))
            .body("description", equalTo("Updated description"))
    }

    @Test
    fun `should delete entity`() {
        // Arrange - Create entity first
        val createBody = """
            {
                "name": "to-delete",
                "description": "Will be deleted"
            }
            """

        val entityId = given()
            .baseUri(container.getURI().toString())
            .contentType(ContentType.JSON)
            .body(createBody)
        .`when`()
            .post("/api/entities")
        .then()
            .statusCode(200)
            .extract().path<Int>("id")

        // Act - Delete
        given()
            .baseUri(container.getURI().toString())
            .pathParam("id", entityId)
        .`when`()
            .delete("/api/entities/{id}")
        .then()
            .statusCode(204)

        // Assert - Verify deleted
        given()
            .baseUri(container.getURI().toString())
            .pathParam("id", entityId)
        .`when`()
            .get("/api/entities/{id}")
        .then()
            .statusCode(404)
    }

    @Test
    fun `should return 404 for not found entity`() {
        given()
            .baseUri(container.getURI().toString())
            .pathParam("id", 99999)
        .`when`()
            .get("/api/entities/{id}")
        .then()
            .statusCode(404)
    }
}

# Kora Tracing Configuration
tracing {
    exporter {
        endpoint = "http://localhost:4317"  # gRPC (recommended) or HTTP: http://localhost:4318/v1/traces
        connectTimeout = "60s"
        exportTimeout = "3s"
        compression = "gzip"  # or "none" for Zipkin
        attributes {
            "service.name" = "my-service"
            "service.namespace" = "kora"
            "service.version" = "1.0.0"
            "deployment.environment" = "production"
        }
    }
}

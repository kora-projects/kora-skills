{
  "skill_name": "kora-telemetry",
  "evals": [
    {
      "id": 1,
      "name": "metrics-basic-setup",
      "prompt": "Configure metrics collection in a Kora application using Micrometer. Add the micrometer-module dependency, connect the Prometheus registry, and configure the /metrics endpoint via httpServer.privateApiHttpMetricsPath.",
      "expected_output": "MetricsModule connected, Prometheus registry added, endpoint configured via application.conf",
      "files": [],
      "assertions": [
        {
          "name": "build-gradle-micrometer-module",
          "type": "contains",
          "target": "build.gradle",
          "content": "ru.tinkoff.kora:micrometer-module",
          "description": "micrometer-module dependency added"
        },
        {
          "name": "build-gradle-prometheus-registry",
          "type": "contains",
          "target": "build.gradle",
          "content": "io.micrometer:micrometer-registry-prometheus",
          "description": "Prometheus registry dependency added"
        },
        {
          "name": "application-metrics-module",
          "type": "contains",
          "target": "Application.java",
          "content": "MetricsModule",
          "description": "MetricsModule connected to Application"
        },
        {
          "name": "application-conf-metrics-path",
          "type": "contains",
          "target": "application.conf",
          "content": "privateApiHttpMetricsPath",
          "description": "Metrics endpoint path configured"
        },
        {
          "name": "application-conf-metrics-path-value",
          "type": "contains",
          "target": "application.conf",
          "content": "/metrics",
          "description": "Metrics endpoint set to /metrics"
        }
      ]
    },
    {
      "id": 2,
      "name": "tracing-grpc-exporter-setup",
      "prompt": "Configure distributed tracing via OpenTelemetry gRPC exporter in Kora. Endpoint: http://jaeger:4317, service.name: my-service, compression: gzip.",
      "expected_output": "OpentelemetryGrpcExporterModule connected, endpoint configured, service.name attributes added",
      "files": [],
      "assertions": [
        {
          "name": "build-gradle-tracing-exporter",
          "type": "contains",
          "target": "build.gradle",
          "content": "ru.tinkoff.kora:opentelemetry-tracing-exporter-grpc",
          "description": "opentelemetry-tracing-exporter-grpc dependency added"
        },
        {
          "name": "application-tracing-module",
          "type": "contains",
          "target": "Application.java",
          "content": "OpentelemetryGrpcExporterModule",
          "description": "OpentelemetryGrpcExporterModule connected to Application"
        },
        {
          "name": "application-conf-tracing-endpoint",
          "type": "contains",
          "target": "application.conf",
          "content": "endpoint = \"http://jaeger:4317\"",
          "description": "Tracing exporter endpoint configured"
        },
        {
          "name": "application-conf-service-name",
          "type": "contains",
          "target": "application.conf",
          "content": "\"service.name\" = \"my-service\"",
          "description": "service.name attribute added"
        },
        {
          "name": "application-conf-compression",
          "type": "contains",
          "target": "application.conf",
          "content": "compression = \"gzip\"",
          "description": "gzip compression enabled"
        }
      ]
    },
    {
      "id": 3,
      "name": "logging-logback-setup",
      "prompt": "Configure logging via Logback in a Kora application. Add LogbackModule, create logback.xml with an async appender and console output.",
      "expected_output": "LogbackModule connected, logback.xml created with KoraAsyncAppender",
      "files": [],
      "assertions": [
        {
          "name": "build-gradle-logback",
          "type": "contains",
          "target": "build.gradle",
          "content": "ru.tinkoff.kora:logging-logback",
          "description": "logging-logback dependency added"
        },
        {
          "name": "application-logback-module",
          "type": "contains",
          "target": "Application.java",
          "content": "LogbackModule",
          "description": "LogbackModule connected to Application"
        },
        {
          "name": "logback-xml-exists",
          "type": "regex",
          "target": "logback.xml",
          "content": "<configuration>",
          "description": "logback.xml exists"
        },
        {
          "name": "logback-async-appender",
          "type": "contains",
          "target": "logback.xml",
          "content": "KoraAsyncAppender",
          "description": "KoraAsyncAppender is used"
        },
        {
          "name": "logback-console-appender",
          "type": "contains",
          "target": "logback.xml",
          "content": "ConsoleAppender",
          "description": "ConsoleAppender configured"
        },
        {
          "name": "logback-root-level",
          "type": "regex",
          "target": "logback.xml",
          "content": "<root level=\"(INFO|DEBUG)\">",
          "description": "Root logger level configured"
        }
      ]
    },
    {

    {
      "id": 5,
      "name": "custom-tracing-span",
      "prompt": "Create a service with custom tracing. Use Tracer to create spans, set OK/ERROR status, and record exceptions via recordException.",
      "expected_output": "Service with custom spans, correct error handling, and span closing",
      "files": [],
      "assertions": [
        {
          "name": "tracer-injection",
          "type": "contains",
          "target": "MyService.java",
          "content": "Tracer tracer",
          "description": "Tracer injected into service"
        },
        {
          "name": "span-builder",
          "type": "contains",
          "target": "MyService.java",
          "content": "tracer.spanBuilder",
          "description": "Span created via spanBuilder"
        },
        {
          "name": "opentelemetry-context",
          "type": "contains",
          "target": "MyService.java",
          "content": "OpentelemetryContext",
          "description": "OpentelemetryContext is used"
        },
        {
          "name": "span-status-ok",
          "type": "contains",
          "target": "MyService.java",
          "content": "StatusCode.OK",
          "description": "Status OK is set"
        },
        {
          "name": "span-status-error",
          "type": "contains",
          "target": "MyService.java",
          "content": "StatusCode.ERROR",
          "description": "Status ERROR is set"
        },
        {
          "name": "record-exception",
          "type": "contains",
          "target": "MyService.java",
          "content": "recordException",
          "description": "Exceptions recorded in span"
        },
        {
          "name": "span-end",
          "type": "contains",
          "target": "MyService.java",
          "content": "span.end()",
          "description": "Span closed in finally"
        }
      ]
    },
    {
      "id": 6,
      "name": "http-server-telemetry",
      "prompt": "Configure telemetry for the HTTP server: enable logging, metrics, tracing for httpServer. Log requestHeaders: X-Request-Id, User-Agent.",
      "expected_output": "Telemetry configuration for httpServer with logging, metrics, tracing",
      "files": [],
      "assertions": [
        {
          "name": "http-server-telemetry-section",
          "type": "regex",
          "target": "application.conf",
          "content": "httpServer\\s*\\{[^}]*telemetry",
          "description": "Telemetry section inside httpServer"
        },
        {
          "name": "telemetry-logging-enabled",
          "type": "regex",
          "target": "application.conf",
          "content": "logging\\s*\\{[^}]*enabled\\s*=\\s*true",
          "description": "Telemetry logging enabled"
        },
        {
          "name": "telemetry-metrics-enabled",
          "type": "regex",
          "target": "application.conf",
          "content": "metrics\\s*\\{[^}]*enabled\\s*=\\s*true",
          "description": "Telemetry metrics enabled"
        },
        {
          "name": "telemetry-tracing-enabled",
          "type": "regex",
          "target": "application.conf",
          "content": "tracing\\s*\\{[^}]*enabled\\s*=\\s*true",
          "description": "Telemetry tracing enabled"
        },
        {
          "name": "request-headers-config",
          "type": "contains",
          "target": "application.conf",
          "content": "X-Request-Id",
          "description": "Logged request headers configured"
        }
      ]
    },

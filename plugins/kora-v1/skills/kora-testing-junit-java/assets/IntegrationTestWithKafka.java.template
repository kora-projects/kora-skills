@Testcontainers
@KoraAppTest(Application.class)
class ${producerName}Test implements KoraAppTestConfigModifier {

    @Container
    static final KafkaContainer KAFKA = new KafkaContainer(
        DockerImageName.parse("confluentinc/cp-kafka:7.5.0")
    ).withStartupTimeout(java.time.Duration.ofSeconds(60));

    @TestComponent
    private ${producerName} ${producerVarName};

    @TestComponent
    private ${consumerName} ${consumerVarName};

    @NotNull
    @Override
    public KoraConfigModification config() {
        // Kora Kafka config is per-listener / per-publisher. The broker address goes into
        // driverProperties using native Kafka client property names. There is no flat
        // kafka.bootstrapServers key. Match these paths to your @KafkaListener strings.
        return KoraConfigModification.ofString("""
            kafka {
                ${consumerConfigPath} {
                    topics = ["${topicName}"]
                    offset = "earliest"
                    driverProperties {
                        "bootstrap.servers" = ${KAFKA_BOOTSTRAP_SERVERS}
                        "group.id" = "test-consumer-group"
                    }
                }
                ${producerConfigPath} {
                    driverProperties {
                        "bootstrap.servers" = ${KAFKA_BOOTSTRAP_SERVERS}
                    }
                }
            }
            """)
            .withSystemProperty("KAFKA_BOOTSTRAP_SERVERS", KAFKA.getBootstrapServers());
    }


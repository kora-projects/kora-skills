    /**
     * Processing with manual offset commit for exactly-once semantics.
     *
     * USE FOR: Transaction processing, synchronization with database writes.
     * COMMIT: Manual - you control when offset is committed.
     * GUARANTEE: Message will be reprocessed if commit fails.
     *
     * IMPORTANT:
     * - Always commit AFTER business logic completes successfully
     * - Commit in catch block if partial progress should be saved
     * - Don't commit on error to trigger reprocessing
     */
    @KafkaListener("kafka.consumer.${listenerName}")
    void processWithManualCommit(ConsumerRecord<String, String> record,
                                  Consumer<String, String> consumer) {
        try {
            log.info("Processing record: offset={}, value={}",
                record.offset(), record.value());

            // TODO: Implement business logic (e.g., save to database)
            processBusinessLogic(record.value());

            // Manual commit AFTER successful processing
            consumer.commitSync();
            log.debug("Offset committed successfully for offset={}", record.offset());

        } catch (Exception e) {
            log.error("Processing failed, offset will not be committed: offset={}",
                record.offset(), e);

            // Don't commit - message will be retried after backoffTimeout
            // Consider: Send to DLQ after max retries (track in Redis/DB)
            throw e; // Triggers backoffTimeout retry
        }
    }

    /**
     * Processing with skip logic for invalid messages.
     *
     * USE FOR: Messages with invalid data that should never be processed.
     * BEHAVIOR: KafkaSkipRecordException skips current message and continues.
     * METRICS: Skipped messages are tracked in Kafka consumer metrics.
     */
    @KafkaListener("kafka.consumer.${listenerName}")
    void processWithSkip(String value) {
        // Validation: skip null/blank values
        if (value == null || value.isBlank()) {
            throw new KafkaSkipRecordException(
                new IllegalArgumentException("Null or blank value received")
            );
        }

        // Validation: skip invalid format
        if (!isValid(value)) {
            throw new KafkaSkipRecordException(
                new IllegalArgumentException("Invalid value format: " + value)
            );
        }

        log.info("Received valid value: {}", value);

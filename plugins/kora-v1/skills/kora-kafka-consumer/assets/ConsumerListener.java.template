    /**
     * Batch processing with manual commit and intermediate commits.
     *
     * USE FOR: Large batches where partial progress should be saved.
     * COMMIT: Manual every N messages for fault tolerance.
     * BENEFIT: If failure occurs, only uncommitted messages are retried.
     */
    @KafkaListener("kafka.consumer.${listenerName}")
    void processBatchWithIntermediateCommit(ConsumerRecords<String, String> records,
                                             Consumer<String, String> consumer) {
        int processed = 0;
        int commitBatchSize = 50;  // Commit every N messages

        for (ConsumerRecord<String, String> record : records) {
            try {
                processBusinessLogic(record.value());
                processed++;

                // Intermediate commit every N messages
                if (processed % commitBatchSize == 0) {
                    consumer.commitSync();
                    log.info("Committed after {} messages (offset={})",
                        processed, record.offset());
                }

            } catch (Exception e) {
                log.error("Failed at offset={}", record.offset(), e);

                // Commit successful messages before rethrowing
                if (processed > 0) {
                    consumer.commitSync();
                }
                throw e; // Trigger backoff for failed message
            }
        }

        // Final commit for remaining messages
        consumer.commitSync();
        log.info("Batch complete: {} records processed", processed);
    }


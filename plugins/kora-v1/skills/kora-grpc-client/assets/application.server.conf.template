grpcServer {
    port = 8090
    maxMessageSize = "4MiB"
    reflectionEnabled = false  # Set true for gRPC CLI tools / debugging
    shutdownWait = "30s"
    telemetry {
        logging {
            enabled = true
        }
        metrics {
            enabled = true
            slo = [ 1, 10, 50, 100, 200, 500, 1000, 2000, 5000, 10000 ]
        }
        tracing {
            enabled = true
        }
    }
}

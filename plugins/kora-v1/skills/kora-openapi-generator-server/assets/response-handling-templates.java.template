          $ref: '#/components/schemas/UserListResponse'
```

```java
@Override
public UserApiResponses.ListUsersApiResponse listUsers(int offset, int limit) {
    var page = userService.findAll(offset, limit);

    return new ListUsers200ApiResponse(
        mapper.toResponse(page),
        String.valueOf(page.total())  // Header value
    );
}
```

## Kotlin Pattern Matching

Kotlin's `when` expression for elegant handling:

```kotlin
override fun getUser(userId: String): UserApiResponses.GetUserApiResponse {
    return userService.findById(userId)
        .map { user ->
            UserApiResponses.GetUserApiResponse.GetUser200ApiResponse(
                mapper.toResponse(user)
            )
        }
        .orElseGet {
            UserApiResponses.GetUserApiResponse.GetUser404ApiResponse(
                ErrorResponseTO("User not found: $userId")
            )
        }
}

override fun deleteUser(userId: String): UserApiResponses.DeleteUserApiResponse {
    return when {
        !userService.exists(userId) ->
            UserApiResponses.DeleteUserApiResponse.DeleteUser404ApiResponse(
                ErrorResponseTO("Not found: $userId")
            )
        else -> {
            userService.delete(userId)
            UserApiResponses.DeleteUserApiResponse.DeleteUser204ApiResponse()
        }
    }
}
```

## Response with Error Details

```java
public record ErrorResponseTO(
    String code,
    String message,
    List<ErrorDetailTO> details
) {}

public record ErrorDetailTO(
    String field,
    String message,
    Object rejectedValue
) {}

// Usage in delegate
@Override
public CreateUserApiResponse createUser(CreateUserRequest request) {
    List<ErrorDetailTO> details = new ArrayList<>();

    if (!isValidEmail(request.email())) {
        details.add(new ErrorDetailTO("email", "Invalid email format", request.email()));
    }

    if (request.password().length() < 8) {
        details.add(new ErrorDetailTO("password", "Must be at least 8 characters", null));
    }

    if (!details.isEmpty()) {
        return new CreateUser400ApiResponse(
            new ErrorResponseTO("VALIDATION_ERROR", "Invalid input", details)
        );
    }

    // ... proceed with creation
}
```

## Exception-to-Response Mapping

Prefer modelling errors as declared status codes in the contract so they become
generated `*ApiResponse` records. For cross-cutting failures, register an
`HttpServerInterceptor` that catches the exception and builds the response with
`HttpServerResponse.of(...)`. The interceptor signature is
`intercept(Context, HttpServerRequest, InterceptChain)` and you continue the
chain with `chain.process(context, request)`.

```java
import java.util.concurrent.CompletionStage;
import ru.tinkoff.kora.common.Component;
import ru.tinkoff.kora.common.Context;
import ru.tinkoff.kora.http.common.body.HttpBody;
import ru.tinkoff.kora.http.server.common.HttpServerInterceptor;
import ru.tinkoff.kora.http.server.common.HttpServerRequest;
import ru.tinkoff.kora.http.server.common.HttpServerResponse;

@Component
public final class GlobalExceptionInterceptor implements HttpServerInterceptor {

    @Override
    public CompletionStage<HttpServerResponse> intercept(
            Context context, HttpServerRequest request, InterceptChain chain) throws Exception {
        return chain.process(context, request).exceptionally(error ->
            HttpServerResponse.of(500, HttpBody.plaintext("An unexpected error occurred")));
    }
}
```

To map one specific exception type to a response body for a handler return value,
use `HttpServerResponseMapper<T>` whose method is
`apply(Context, HttpServerRequest, T)` and returns `HttpServerResponse.of(...)`.

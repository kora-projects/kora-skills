# Multi-stage Dockerfile for a Kora Java application
# Builds the application inside Docker + minimal runtime image
#
# Advantages:
# - No local Gradle/JDK required on the host
# - Reproducible build in CI/CD
# - JDK 25 for the build stage, JRE 25 for the runtime stage
#
# Usage:
#   docker build -t myapp:1.0.0 .
#   docker run -p 8080:8080 -p 8085:8085 myapp:1.0.0

# ============================================
# Stage 1: Build (JDK 25, Alpine)
# ============================================
FROM gradle:9.5.1-jdk25-alpine AS build

WORKDIR /home/gradle/src

# Copy only build files to cache dependencies
COPY build.gradle* settings.gradle* gradle.properties* ./
COPY gradle/ ./gradle/

# Cache dependencies (layer is rebuilt only when build.gradle changes)
RUN gradle dependencies --no-daemon || true

# Copy source code
COPY . .

# Build the distribution
RUN gradle installDist --no-daemon

# ============================================
# Stage 2: Runtime (JRE 25, Jammy)
# ============================================
ARG RUN_IMAGE=eclipse-temurin:25-jre-jammy
FROM ${RUN_IMAGE}

ARG TARGET_DIR=/opt/app

# Copy the distribution from the build stage
COPY --from=build /home/gradle/src/build/distributions/*.tar application.tar

RUN mkdir $TARGET_DIR && \
    tar -xf application.tar -C $TARGET_DIR && \
    rm application.tar

# Create a non-root user for security
ARG DOCKER_USER=app
RUN groupadd -r $DOCKER_USER && useradd -rg $DOCKER_USER $DOCKER_USER
USER $DOCKER_USER

# Ports: 8080 (API), 8085 (system endpoints: health, metrics, readiness)
EXPOSE 8080/tcp
EXPOSE 8085/tcp

# Health check for Kubernetes/Docker
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:8085/system/readiness || exit 1

CMD [ "/opt/app/application/bin/application" ]
